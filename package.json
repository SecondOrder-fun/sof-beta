{
  "name": "sof-beta",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "NETWORK=local turbo dev",
    "build": "echo '\n                        ╭───────────╮\n        ┌───┐           │  turbo-   │\n        │ T │__    ╱────│  tastic!  │\n        │ °‿°│  \\ ╱     ╰───────────╯\n        └─┬──┘  ─╱\n     ┌────┴────────┐\n     │  ▄▀▀▀▄  ▀▀ │\n     └─●────────●──┘\n' && turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "deploy:contracts": "turbo deploy:contracts",
    "deploy:env": "bash ./scripts/deploy-env.sh",
    "deploy:env:dry": "bash ./scripts/deploy-env.sh --dry-run",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:deploy": "./scripts/docker-deploy-local.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "overrides": {
    "ox": "0.14.7"
  },
  "packageManager": "npm@10.9.1"
}
