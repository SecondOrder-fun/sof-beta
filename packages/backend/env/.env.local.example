# packages/backend/env/.env.local.example
#
# Backend runtime env vars for LOCAL development.
# These are loaded from .env.local (gitignored) by dotenv.
#
# Copy this file to .env.local and fill in values.

# ── Required (boot fails without these — shared/assertRequiredEnv.js) ──
NETWORK=LOCAL
NODE_ENV=development

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

RPC_URL=http://127.0.0.1:8545

# Backend wallet — derive ADDRESS from PRIVATE_KEY; assertRequiredEnv enforces match.
# Anvil default account #0:
BACKEND_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BACKEND_WALLET_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# JWT signing — must be ≥32 chars. Generate fresh: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Paymaster + bundler. Both required always; on LOCAL points at Anvil.
PAYMASTER_RPC_URL=http://127.0.0.1:8545
# PIMLICO_API_KEY is optional on LOCAL; only needed if testing ERC-7677 via testnet bundler

# ── Redis ──
# On LOCAL, set to empty or point to local redis:6379
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENV=

# ── Auth / SIWF ──
SIWF_DOMAIN=localhost:5174
SIWF_ALLOWED_DOMAINS=localhost:5174,localhost:3000,127.0.0.1:5174,127.0.0.1:3000

# ── Rate limiting ──
RATE_LIMIT_MAX=1000
RATE_LIMIT_TIMEWINDOW=1 minute

# ── Feature integrations ──
NEYNAR_API_KEY=
# Blockscout proxy (optional on LOCAL; required on TESTNET/MAINNET)
BLOCKSCOUT_BASE_URL=
BLOCKSCOUT_API_KEY=

# Hats Protocol — only needed if Hats sponsor-hat integration is active
HATS_PROTOCOL=
HATS_SPONSOR_HAT_ID=
HATS_STAKING_ELIGIBILITY=

# Season lifecycle interval ms (defaults sane)
# SEASON_LIFECYCLE_INTERVAL_MS=

SOF_AIRDROP_AMOUNT_PER_USER=100
