# packages/backend/env/.env.mainnet.example
#
# Backend runtime env vars for the mainnet (Base) deploy.
# Pushed to Railway by `./scripts/deploy-env.sh --network mainnet`.
#
# Same shape as .env.testnet.example. Differences: NETWORK=MAINNET,
# CORS_ORIGINS includes the production custom domain, mainnet RPC URLs.

# ── Required ──
NETWORK=MAINNET
NODE_ENV=production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

RPC_URL=

BACKEND_WALLET_PRIVATE_KEY=
BACKEND_WALLET_ADDRESS=

JWT_SECRET=
JWT_EXPIRES_IN=7d

PAYMASTER_RPC_URL=
PIMLICO_API_KEY=

CORS_ORIGINS=https://secondorder.fun,https://sof-beta-frontend.vercel.app

# ── Redis ──
REDIS_URL=
REDIS_ENV=

# ── Auth / SIWF ──
SIWF_DOMAIN=secondorder.fun
SIWF_ALLOWED_DOMAINS=secondorder.fun

# ── Rate limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=1 minute

# ── Feature integrations ──
NEYNAR_API_KEY=
HATS_PROTOCOL=
HATS_SPONSOR_HAT_ID=
HATS_STAKING_ELIGIBILITY=
