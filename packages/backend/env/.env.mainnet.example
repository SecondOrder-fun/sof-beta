# Backend — Mainnet (Base)
# Copy to .env.mainnet and fill in values

PORT=3000
NODE_ENV=production
NETWORK=mainnet

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

REDIS_ENV=prod
REDIS_URL=

RPC_URL=https://mainnet.base.org
BACKEND_WALLET_PRIVATE_KEY=
BACKEND_WALLET_ADDRESS=
ETHERSCAN_API_KEY=

JWT_SECRET=
JWT_EXPIRES_IN=7d
NEYNAR_API_KEY=
SIWF_ALLOWED_DOMAINS=secondorder.fun

CORS_ORIGINS=https://secondorder.fun

PAYMASTER_RPC_URL=https://api.developer.coinbase.com/rpc/v1/base/your-key

RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000
