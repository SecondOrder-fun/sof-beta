# packages/backend/env/.env.testnet.example
#
# Backend runtime env vars for the testnet (Base Sepolia) deploy.
# These are pushed to Railway by `./scripts/deploy-env.sh --network testnet`
# and become the deployed service's environment.
#
# Copy this file to .env.testnet and fill in real values.
# .env.testnet is gitignored.
#
# DO NOT add VITE_* vars here — those go in packages/frontend/env/.env.testnet.
# DO NOT add Vercel/Railway API tokens here — those go in .env.platform (root).
# DO NOT add PORT — Railway auto-injects it.

# ── Required (boot fails without these — shared/assertRequiredEnv.js) ──
NETWORK=TESTNET
NODE_ENV=production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Base Sepolia HTTP RPC. Public endpoint is https://sepolia.base.org
# but rate-limits — prefer a paid Alchemy/Infura key for serious testing.
RPC_URL=

# Backend wallet — derive ADDRESS from PRIVATE_KEY; assertRequiredEnv enforces match.
BACKEND_WALLET_PRIVATE_KEY=
BACKEND_WALLET_ADDRESS=

# JWT signing — must be ≥32 chars. Generate fresh: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Pimlico ERC-7677 paymaster + bundler. Both required when NETWORK != LOCAL.
# Get key + RPC URL from https://dashboard.pimlico.io
PAYMASTER_RPC_URL=
PIMLICO_API_KEY=

# CORS allowlist — comma-separated origins. Required when NODE_ENV=production.
# Add the Vercel public URL + any custom domain.
CORS_ORIGINS=https://sof-beta-frontend.vercel.app

# ── Redis (used for admin access cache + rate limiting) ──
# REDIS_ENV selects which REDIS_URL_* to use. Or set REDIS_URL directly.
REDIS_URL=
REDIS_ENV=

# ── Auth / SIWF ──
# SIWF_ALLOWED_DOMAINS supports wildcards (*.vercel.app) for preview deploys.
SIWF_DOMAIN=secondorder.fun
SIWF_ALLOWED_DOMAINS=secondorder.fun,*.vercel.app

# ── Rate limiting (@fastify/rate-limit) ──
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=1 minute

# ── Feature integrations ──
NEYNAR_API_KEY=

# Hats Protocol — only needed if Hats sponsor-hat integration is active
HATS_PROTOCOL=
HATS_SPONSOR_HAT_ID=
HATS_STAKING_ELIGIBILITY=

# Paymaster operational config (defaults are sane; override only if needed)
# PAYMASTER_ADDRESS=
# PAYMASTER_QUOTA_PER_HOUR=
# PAYMASTER_VALIDITY_WINDOW_SEC=

# Oracle alerting (defaults sane)
# ORACLE_ALERT_CUTOFF=
# ORACLE_MAX_RETRIES=

# Season lifecycle interval ms (defaults sane)
# SEASON_LIFECYCLE_INTERVAL_MS=

# Backend-side chain identification (some scripts read these explicitly).
# Usually unnecessary — derived from NETWORK at the chain config layer.
# CHAIN_ID=84532
# CHAIN_NAME=Base Sepolia
