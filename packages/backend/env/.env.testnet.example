# Backend — Testnet (Base Sepolia)
# Copy to .env.testnet and fill in values

PORT=3000
NODE_ENV=production
NETWORK=testnet

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_ENV=dev
REDIS_URL=

# Blockchain
RPC_URL=https://sepolia.base.org
BACKEND_WALLET_PRIVATE_KEY=
BACKEND_WALLET_ADDRESS=
ETHERSCAN_API_KEY=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
NEYNAR_API_KEY=
SIWF_ALLOWED_DOMAINS=secondorder.fun,*.vercel.app

# CORS
CORS_ORIGINS=http://localhost:5173,https://secondorder.fun,https://*.vercel.app

# Paymaster
PAYMASTER_RPC_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia/your-key

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000
