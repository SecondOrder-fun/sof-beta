{
  "name": "@sof/backend",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "description": "SecondOrder.fun Backend API Server",
  "scripts": {
    "dev": "source ../../scripts/load-env.sh && node -r dotenv/config fastify/server.js",
    "start": "node -r dotenv/config fastify/server.js",
    "build": "echo 'No build step'",
    "test": "vitest run",
