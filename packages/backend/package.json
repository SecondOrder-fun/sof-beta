    "@fastify/rate-limit": "^10.3.0",
    "@sof/contracts": "*",
    "@supabase/supabase-js": "^2.53.1",
    "axios": "^1.12.2",
    "dotenv": "^17.2.1",
    "fastify": "^5.4.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "viem": "^2.33.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
