# packages/contracts/env/.env.testnet.example
#
# Used by Foundry deploy scripts (forge script) for testnet (Base Sepolia).
# Sourced locally before `forge script ... --broadcast`. NEVER pushed to
# Vercel/Railway — these are local-only for contract deploys.
#
# Copy to .env.testnet, fill values, then:
#   source env/.env.testnet
#   forge script script/deploy/DeployAll.s.sol:DeployAll \
#     --rpc-url https://sepolia.base.org --broadcast --verify --force

# Deployer wallet private key (must have Sepolia ETH for gas)
PRIVATE_KEY=

# Chainlink VRF v2.5 subscription ID (Base Sepolia coordinator).
# Created at https://vrf.chain.link
VRF_SUBSCRIPTION_ID=

# Etherscan / Basescan API key for `forge verify`
ETHERSCAN_API_KEY=

# Treasury wallet that receives bonding-curve fees + raffle rake.
# (Some scripts read TREASURY, others TREASURY_ADDRESS — set both to be safe.)
TREASURY=
TREASURY_ADDRESS=

# Used by season-creation scripts (script/admin/CreateSeason.s.sol etc.)
SEASON_NAME="Season 1"
DURATION_SECS=2592000
START_TIME=

# Raffle contract address (set after DeployAll, used by post-deploy scripts)
RAFFLE=
