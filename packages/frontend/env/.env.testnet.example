# packages/frontend/env/.env.testnet.example
#
# Frontend BUILD-TIME env vars for the testnet (Base Sepolia) deploy.
# These are pushed to Vercel by `./scripts/deploy-env.sh --network testnet`
# and BAKED INTO THE BUILD by Vite — env-var changes do not affect already-
# built deployments. After updating these, redeploy on Vercel without cache.
#
# Copy this file to .env.testnet and fill in real values. .env.testnet is gitignored.
#
# DO NOT add anything without VITE_ prefix — Vite won't expose it to the client.
# DO NOT add backend secrets (SUPABASE_SERVICE_ROLE_KEY, JWT_SECRET, etc.) — those
#   would leak into the public bundle.
# DO NOT add Vercel/Railway API tokens here.

# ── Required ──
VITE_NETWORK=TESTNET

# Backend API base. Must include the /api path suffix because call sites
# concat `${API_BASE}/auth/nonce` etc.
VITE_API_BASE_URL=https://sof-backend-production-686a.up.railway.app/api

# Backend WebSocket. No path suffix — the WS client appends as needed.
VITE_BACKEND_WS_URL=wss://sof-backend-production-686a.up.railway.app

# Chain identification.
VITE_CHAIN_ID=84532
VITE_CHAIN_NAME=Base Sepolia

# Chain HTTP RPC (Base Sepolia). Public is https://sepolia.base.org but
# rate-limits — prefer Alchemy/Infura key for serious testing.
VITE_RPC_URL=

# WalletConnect — get a Project ID from https://cloud.reown.com (formerly walletconnect)
VITE_WALLETCONNECT_PROJECT_ID=

VITE_EXPLORER=https://sepolia.basescan.org

# ── Optional ──

# Chain WebSocket RPC. Used by viem watchEvent for live on-chain subscriptions.
# Leave blank to fall back to HTTP polling.
VITE_WS_URL=

# Mintclub network selector for the airdrop integration. Defaults to "base" if unset.
# VITE_MINTCLUB_NETWORK=base
