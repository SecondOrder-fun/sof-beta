# packages/frontend/env/.env.mainnet.example
#
# Frontend BUILD-TIME env vars for the mainnet (Base) deploy.
# Pushed to Vercel by `./scripts/deploy-env.sh --network mainnet`.

# ── Required ──
VITE_NETWORK=MAINNET

VITE_API_BASE_URL=https://<mainnet-railway-host>/api
VITE_BACKEND_WS_URL=wss://<mainnet-railway-host>

VITE_CHAIN_ID=8453
VITE_CHAIN_NAME=Base
VITE_RPC_URL=

VITE_WALLETCONNECT_PROJECT_ID=

VITE_EXPLORER=https://basescan.org

# ── Optional ──
VITE_WS_URL=
# VITE_MINTCLUB_NETWORK=base
