{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NETWORK"],
  "globalPassThroughEnv": ["VITE_*", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "abi/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "deploy:contracts": {
      "cache": false
    }
  }
}
