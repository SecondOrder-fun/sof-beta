# .env.platform.example (root)
#
# Auth credentials for the deploy-env scripts (sync-env-vercel.sh,
# sync-env-railway.sh). Read by ./scripts/deploy-env.sh ONLY.
# These tokens are NEVER pushed to Vercel or Railway as runtime env vars —
# they are the script's own credentials for hitting the providers' APIs.
#
# Copy this file to .env.platform and fill in values. .env.platform is
# gitignored.

# ── Vercel ──
# VERCEL_TOKEN: create at https://vercel.com/account/tokens
# VERCEL_PROJECT_ID + VERCEL_TEAM_ID: easiest via `cd packages/frontend && npx vercel link`
#   then `cat packages/frontend/.vercel/project.json` (orgId → TEAM_ID, projectId → PROJECT_ID).
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ── Railway ──
# Use ONE of the two token types. Both work; the script auto-detects which is
# set and uses the correct auth header (Bearer vs Project-Access-Token).
#
# RAILWAY_API_TOKEN: account or workspace token from https://railway.com/account/tokens
#   Read access to all projects in the chosen scope. Use this for general script work.
# RAILWAY_TOKEN: project token from Project Settings → Tokens
#   Scoped to one project but has FULL mutation rights including environmentCreate.
#   Required if you hit "Not Authorized" on mutations with an account/workspace token.
RAILWAY_API_TOKEN=
RAILWAY_TOKEN=

RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
